# Copy this file to ".env" and fill in your real keys.
# .env is gitignored — never commit it.

NOTION_TOKEN=ntn_your_notion_internal_integration_token
OPENAI_API_KEY=sk-your_openai_key
ANTHROPIC_API_KEY=sk-ant-your_anthropic_key

# Optional test override: point this at a local image (e.g. the Stian photo)
# to use it as the hero image instead of looking in Notion. Leave empty normally.
LOCAL_PHOTO_PATH=
